# HTV-Agent model backend (OpenAI-compatible). No real credentials are stored
# in this repo — fill these in for your own endpoint. Copy to .env and edit.
HTV_AGENT_OPENAI_API_KEY=<OPENAI_API_KEY>
HTV_AGENT_OPENAI_BASE_URL=<OPENAI_BASE_URL>
HTV_AGENT_MODEL=gemini-3.5-flash

# High-effort settings used for the paper's inference-time judge ablation.
HTV_AGENT_MAX_TOKENS=8192
HTV_AGENT_REASONING_EFFORT=high
HTV_AGENT_MODEL_TIMEOUT_SECONDS=600
HTV_AGENT_MAX_SOLVER_STEPS=16
HTV_AGENT_MAX_VERIFIER_STEPS=10

# Enable the programmatic (python_exec) evidence channel. Only turn on in a
# trusted environment — it executes model-authored Python locally.
HTV_AGENT_ENABLE_PYTHON_EXEC_TOOL=false
